<div class="fundo">
  <div class="container-central">
    <div class="card borda-primaria">
      
      <div class="card-header cabecalho-primario">
        <h2 class="titulo">AVALIAÇÃO DE ORÇAMENTO</h2>
      </div>

      <div class="card-body">
        
        <div class="secao-dados mb-4">
          <h5 class="subtitulo-secao mb-3">Detalhes da Solicitação</h5>
          <div class="row gy-3">
            <div class="col-md-6">
              <p class="mb-1"><span class="fw-bold text-muted">Equipamento:</span> Notebook Dell Inspiron</p>
              <p class="mb-1"><span class="fw-bold text-muted">Categoria:</span> Computador</p>
            </div>
            <div class="col-md-6">
              <p class="mb-1"><span class="fw-bold text-muted">Data de Abertura:</span> 15/10/2023 14:30</p>
              <p class="mb-1"><span class="fw-bold text-muted">Status Atual:</span> <span class="badge bg-warning text-dark">ORÇADA</span></p>
            </div>
            <div class="col-12 mt-3">
              <p class="mb-1"><span class="fw-bold text-muted">Defeito Relatado:</span></p>
              <p class="caixa-texto-simples">Tela piscando intermitentemente e a bateria não segura carga por mais de 10 minutos após desconectar da tomada.</p>
            </div>
          </div>
        </div>

        <div class="orcamento-destaque mb-4 text-center">
          <p class="orcamento-label">Valor Total Orçado</p>
          <h3 class="orcamento-valor">R$ 525,00</h3>
          <p class="aviso-orcamento mt-2 mb-0">
            <small>Técnico responsável: João Silva | Validade: 7 dias</small>
          </p>
        </div>

        <div class="botoes-acao d-flex justify-content-center gap-3 mt-4">
          <button 
            type="button" 
            class="btn btn-outline-danger btn-lg w-50 fw-bold"
            (click)="redirecionarParaRejeicao()">
            Rejeitar Serviço
          </button>

          <button 
            type="button" 
            class="btn btn-success btn-lg w-50 fw-bold d-flex align-items-center justify-content-center gap-2"
            (click)="aprovarServico()">
            Aprovar Serviço
          </button>
        </div>

        <div class="text-center mt-4">
          <a href="#" class="texto-cancelar">
            Voltar para a página anterior
          </a>
        </div>

      </div>
    </div>
  </div>
</div>


.fundo {
    background-color: #f0f2f8; 
    min-height: 100vh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
    font-family: 'DM Sans', sans-serif;
}

.container-central {
    width: 100%;
    max-width: 750px; 
}

.borda-primaria {
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
    overflow: hidden;
    background-color: #ffffff;
}

.cabecalho-primario {
    background-color: #4f46e5; 
    color: #ffffff;
    text-align: center;
    padding: 1.25rem;
    border-radius: 0;
    border-bottom: none;
    margin: -1px -1px 0 -1px;
}

.titulo {
    font-family: 'Syne', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 1px;
    margin: 0;
}

.subtitulo-secao {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    color: #1e1b4b;
    font-size: 1.1rem;
}

.secao-dados {
    background-color: #fafbfc;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 1.5rem;
}

.caixa-texto-simples {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 0.95rem;
    color: #1e1b4b;
    margin-bottom: 0;
}

.orcamento-destaque {
    background: linear-gradient(135deg, #ecfeff, #cffafe);
    border: 2px solid #a5f3fc;
    border-radius: 12px;
    padding: 2rem;
}

.orcamento-label {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #0891b2;
    margin-bottom: 0.5rem;
}

.orcamento-valor {
    font-family: 'Syne', sans-serif;
    font-size: 2.5rem;
    font-weight: 800;
    color: #0e7490;
    margin: 0;
}

.aviso-orcamento {
    color: #0891b2;
    font-weight: 500;
}

.texto-cancelar {
    color: #64748b;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s;
}

.texto-cancelar:hover {
    color: #1e1b4b;
    text-decoration: underline;
}

/* --- Responsividade --- */
@media (max-width: 576px) {
    .botoes-acao {
        flex-direction: column;
    }
    
    .botoes-acao .btn {
        width: 100% !important;
    }

    .orcamento-valor {
        font-size: 2rem;
    }
}
